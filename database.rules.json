{
  "rules": {
    ".read": false,
    ".write": false,

    "connections": {
      ".read": true,
      ".indexOn": ["lastSeen", "connectedAt"],
      "$uid": {
        ".write": "auth != null && auth.uid === $uid",
        ".validate": "newData.hasChildren(['odUserId', 'connectedAt'])"
      }
    },

    "queue": {
      ".read": "auth != null",
      "$queueId": {
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['userId', 'sessionId', 'mode', 'timestamp'])"
      }
    },

    "chats": {
      ".read": "auth != null",
      "$chatId": {
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['user1', 'user2', 'session1', 'session2', 'mode', 'createdAt', 'isActive'])",
        ".indexOn": ["createdAt", "isActive"]
      }
    },

    "messages": {
      "$chatId": {
        ".read": "auth != null",
        "$messageId": {
          ".write": "auth != null",
          ".validate": "newData.hasChildren(['senderId', 'text', 'timestamp']) && newData.child('text').isString() && newData.child('text').val().length <= 2000"
        }
      }
    },

    "userChats": {
      "$userId": {
        ".read": "auth != null && auth.uid === $userId",
        ".write": "auth != null"
      }
    },

    "typing": {
      "$chatId": {
        ".read": "auth != null",
        "$userId": {
          ".write": "auth != null && auth.uid === $userId"
        }
      }
    },

    "partnerOnline": {
      "$chatId": {
        ".read": "auth != null",
        "$userId": {
          ".write": "auth != null && auth.uid === $userId"
        }
      }
    },

    "reports": {
      ".read": false,
      "$reportId": {
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['reportedBy', 'reportedUser', 'chatId', 'reason', 'timestamp'])"
      }
    },

    "feedback": {
      "$feedbackId": {
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['userId', 'chatId', 'timestamp'])"
      }
    },

    "bannedDevices": {
      ".read": false,
      ".write": false,
      "$deviceId": {
        ".read": "auth != null"
      }
    },

    "shadowbanned": {
      ".read": false,
      ".write": false,
      "$userId": {
        ".read": "auth != null && auth.uid === $userId"
      }
    },

    "shadowbans": {
      ".read": false,
      ".write": false,
      "$deviceId": {
        ".read": "auth != null"
      }
    },

    "verifiedEmails": {
      ".read": false,
      ".write": false,
      "$userId": {
        ".read": "auth != null && auth.uid === $userId",
        ".write": "auth != null && auth.uid === $userId"
      }
    },

    "verifiedUsers": {
      ".read": false,
      ".write": false,
      "$userId": {
        ".read": "auth != null && auth.uid === $userId",
        ".write": "auth != null && auth.uid === $userId"
      }
    },

    "confessions": {
      ".read": true,
      ".indexOn": ["timestamp", "expiresAt"],
      "$confessionId": {
        ".write": "auth != null",
        ".validate": "!newData.exists() || (newData.hasChild('text') && newData.child('text').isString() && newData.child('text').val().length <= 280)",
        "hearts": {
          ".write": true
        },
        "comments": {
          "$commentId": {
            ".write": "auth != null",
            ".validate": "newData.hasChildren(['text', 'timestamp']) && newData.child('text').isString() && newData.child('text').val().length <= 200"
          }
        }
      }
    },

    "groupChats": {
      ".read": true,
      ".indexOn": ["createdAt", "isActive"],
      "$roomId": {
        ".write": "auth != null",
        ".validate": "!newData.exists() || newData.hasChildren(['isActive', 'createdAt'])"
      }
    },

    "groupMessages": {
      "$roomId": {
        ".read": true,
        "$messageId": {
          ".write": "auth != null",
          ".validate": "newData.hasChildren(['senderId', 'text', 'timestamp']) && newData.child('text').isString() && newData.child('text').val().length <= 2000"
        }
      }
    },

    "meta": {
      "onlineCount": {
        ".read": true,
        ".write": false
      }
    },

    "fcmTokens": {
      "$userId": {
        ".read": "auth != null && auth.uid === $userId",
        ".write": "auth != null && auth.uid === $userId"
      }
    }
  }
}
