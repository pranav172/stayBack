{
  "rules": {
    "connections": {
      ".read": true,
      ".indexOn": ["connectedAt"],
      "$sessionId": {
        ".write": "auth != null && (!data.exists() || data.child('odUserId').val() === auth.uid)",
        ".validate": "newData.hasChildren(['odUserId', 'connectedAt'])"
      }
    },
    
    "queue": {
      ".read": "auth != null",
      ".indexOn": ["timestamp", "mode", "userId"],
      "$pushId": {
        ".write": "auth != null && (!data.exists() || data.child('userId').val() === auth.uid)",
        ".validate": "newData.hasChildren(['userId', 'sessionId', 'mode', 'timestamp']) && newData.child('userId').val() === auth.uid"
      }
    },
    
    "chats": {
      ".read": "auth != null",
      ".indexOn": ["createdAt", "isActive", "session1", "session2"],
      "$chatId": {
        ".write": "auth != null && (!data.exists() || data.child('user1').val() === auth.uid || data.child('user2').val() === auth.uid)",
        ".validate": "newData.hasChildren(['user1', 'user2', 'session1', 'session2', 'createdAt', 'isActive'])"
      }
    },
    
    "userChats": {
      "$odUserId": {
        ".read": "auth != null && auth.uid === $odUserId",
        ".write": "auth != null",
        "$chatId": {
          ".validate": "newData.hasChildren(['sessionId', 'isActive'])"
        }
      }
    },
    
    "messages": {
      "$chatId": {
        ".read": "auth != null && (root.child('chats/' + $chatId + '/user1').val() === auth.uid || root.child('chats/' + $chatId + '/user2').val() === auth.uid)",
        ".indexOn": ["timestamp"],
        "$messageId": {
          ".write": "auth != null && (root.child('chats/' + $chatId + '/user1').val() === auth.uid || root.child('chats/' + $chatId + '/user2').val() === auth.uid) && root.child('chats/' + $chatId + '/isActive').val() === true",
          ".validate": "newData.hasChildren(['senderId', 'text', 'timestamp']) && newData.child('text').val().length <= 500 && newData.child('senderId').val() === auth.uid"
        }
      }
    },
    
    "devices": {
      ".indexOn": ["bannedUntil", "lastSeen"],
      "$deviceId": {
        ".read": "auth != null",
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['odUserId', 'firstSeen'])"
      }
    },
    
    "reports": {
      ".read": "auth != null",
      ".indexOn": ["timestamp", "status"],
      "$reportId": {
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['reporterId', 'reportedUserId', 'chatId', 'reason', 'timestamp', 'status'])"
      }
    },
    
    "feedback": {
      ".read": false,
      "$chatId": {
        "$feedbackId": {
          ".write": "auth != null && !data.exists()"
        }
      }
    },
    
    "bans": {
      ".read": "auth != null",
      ".indexOn": ["odUserId", "deviceId", "expiresAt"],
      "$odUserId": {
        ".write": false
      }
    },
    
    "adminActions": {
      ".read": false,
      ".write": false
    }
  }
}
